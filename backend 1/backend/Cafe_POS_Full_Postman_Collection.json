{
  "info": {
    "name": "Cafe POS Complete Test Suite",
    "description": "Exhaustive API tests covering all 20 modules and Role-Based Access Control (RBAC).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "admin_token", "value": "", "type": "string" },
    { "key": "cashier_token", "value": "", "type": "string" },
    { "key": "kitchen_token", "value": "", "type": "string" },
    { "key": "customer_token", "value": "", "type": "string" },
    { "key": "test_order_id", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "01. Authentication & Role Setup",
      "description": "Logins to capture JWT tokens for different roles.",
      "item": [
        {
          "name": "1. Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('admin_token', jsonData.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": [ "{{baseUrl}}" ], "path": [ "api", "auth", "login" ] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@cafe.com\",\n  \"password\": \"admin123\"\n}" }
          }
        },
        {
          "name": "2. Login Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('customer_token', jsonData.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": [ "{{baseUrl}}" ], "path": [ "api", "auth", "login" ] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"customer@test.com\",\n  \"password\": \"cust123\"\n}" }
          }
        }
      ]
    },
    {
      "name": "02. Admin Only (Requires admin_token)",
      "description": "Operations restricted to the ADMIN role.",
      "item": [
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/employees", "host": [ "{{baseUrl}}" ], "path": [ "api", "employees" ] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Cashier\",\n  \"email\": \"cashier@cafe.com\",\n  \"password\": \"cashier123\",\n  \"role\": \"CASHIER\"\n}" }
          }
        },
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{admin_token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/employees", "host": [ "{{baseUrl}}" ], "path": [ "api", "employees" ] }
          }
        },
        {
          "name": "Create Payment Method",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/payment-methods", "host": [ "{{baseUrl}}" ], "path": [ "api", "payment-methods" ] },
            "body": { "mode": "raw", "raw": "{\n  \"methodName\": \"UPI\",\n  \"enabled\": true,\n  \"upiId\": \"cafe@upi\"\n}" }
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/categories", "host": [ "{{baseUrl}}" ], "path": [ "api", "categories" ] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Beverages\",\n  \"color\": \"#FF5733\"\n}" }
          }
        },
        {
          "name": "Download Daily Sales Report (PDF)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{admin_token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/reports/daily-sales?format=pdf", "host": [ "{{baseUrl}}" ], "path": [ "api", "reports", "daily-sales" ], "query": [ { "key": "format", "value": "pdf" } ] }
          }
        }
      ]
    },
    {
      "name": "03. Cashier & Admin (Requires admin_token or cashier_token)",
      "item": [
        {
          "name": "Open POS Session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/sessions/open", "host": [ "{{baseUrl}}" ], "path": [ "api", "sessions", "open" ] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"openingBalance\": 100.00\n}" }
          }
        },
        {
          "name": "Create Floor",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/floors", "host": [ "{{baseUrl}}" ], "path": [ "api", "floors" ] },
            "body": { "mode": "raw", "raw": "{\n  \"floorName\": \"Main Hall\"\n}" }
          }
        },
        {
          "name": "Create Table",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/tables", "host": [ "{{baseUrl}}" ], "path": [ "api", "tables" ] },
            "body": { "mode": "raw", "raw": "{\n  \"floorId\": 1,\n  \"tableNumber\": \"T1\",\n  \"numberOfSeats\": 4,\n  \"active\": true\n}" }
          }
        }
      ]
    },
    {
      "name": "04. Kitchen & Admin (Requires admin_token or kitchen_token)",
      "item": [
        {
          "name": "Update Kitchen Stage",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Authorization", "value": "Bearer {{admin_token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/kitchen/stage/1?stage=PREPARING", "host": [ "{{baseUrl}}" ], "path": [ "api", "kitchen", "stage", "1" ], "query": [ { "key": "stage", "value": "PREPARING" } ] }
          }
        },
        {
          "name": "Get Active Kitchen Orders",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{admin_token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/kitchen/active", "host": [ "{{baseUrl}}" ], "path": [ "api", "kitchen", "active" ] }
          }
        }
      ]
    },
    {
      "name": "05. Public / Customer (Requires customer_token or No Token)",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": [ "{{baseUrl}}" ], "path": [ "api", "auth", "register" ] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"customer@test.com\",\n  \"password\": \"cust123\"\n}" }
          }
        },
        {
          "name": "Get Products (Menu View)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/products", "host": [ "{{baseUrl}}" ], "path": [ "api", "products" ] }
          }
        },
        {
          "name": "Generate QR Code for Table",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/qr/table/1", "host": [ "{{baseUrl}}" ], "path": [ "api", "qr", "table", "1" ] }
          }
        },
        {
          "name": "Customer Creates Order (Self Order)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('test_order_id', jsonData.orderId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/orders", "host": [ "{{baseUrl}}" ], "path": [ "api", "orders" ] },
            "body": { "mode": "raw", "raw": "{\n  \"tableId\": 1,\n  \"customerId\": 1,\n  \"userId\": 1,\n  \"items\": [\n    {\n      \"productId\": 1,\n      \"quantity\": 2\n    }\n  ]\n}" }
          }
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/orders/{{test_order_id}}/items", "host": [ "{{baseUrl}}" ], "path": [ "api", "orders", "{{test_order_id}}", "items" ] },
            "body": { "mode": "raw", "raw": "{\n  \"productId\": 2,\n  \"quantity\": 1\n}" }
          }
        },
        {
          "name": "Send Order To Kitchen (Checkout)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{customer_token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/kitchen/send/{{test_order_id}}", "host": [ "{{baseUrl}}" ], "path": [ "api", "kitchen", "send", "{{test_order_id}}" ] }
          }
        },
        {
          "name": "Submit Feedback",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/feedback", "host": [ "{{baseUrl}}" ], "path": [ "api", "feedback" ] },
            "body": { "mode": "raw", "raw": "{\n  \"orderId\": {{test_order_id}},\n  \"customerId\": 1,\n  \"rating\": 5,\n  \"comments\": \"Great coffee!\"\n}" }
          }
        }
      ]
    }
  ]
}
